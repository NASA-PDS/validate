<?xml version="1.0" encoding="UTF-8"?>
<!-- This product tests Issue 1481: Internal_Reference in a non-standard (Discipline_Area)
     location should be checked for referential integrity. The Internal_Reference here
     points to product_b which does NOT exist in the bundle - this should generate a warning. -->
<Product_Observational xmlns="http://pds.nasa.gov/pds4/pds/v1"
    xmlns:testldd="http://pds.nasa.gov/pds4/testldd/v1"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://pds.nasa.gov/pds4/pds/v1 https://pds.nasa.gov/pds4/pds/v1/PDS4_PDS_1D00.xsd">
    <Identification_Area>
        <logical_identifier>urn:nasa:pds:test1481:data:product_a</logical_identifier>
        <version_id>1.0</version_id>
        <title>Test Product A for Issue 1481</title>
        <information_model_version>1.13.0.0</information_model_version>
        <product_class>Product_Observational</product_class>
    </Identification_Area>
    <Observation_Area>
        <Time_Coordinates>
            <start_date_time>2020-01-01T00:00:00Z</start_date_time>
            <stop_date_time>2020-01-01T01:00:00Z</stop_date_time>
        </Time_Coordinates>
        <Primary_Result_Summary>
            <purpose>Science</purpose>
            <processing_level>Calibrated</processing_level>
        </Primary_Result_Summary>
        <Investigation_Area>
            <name>Test Investigation</name>
            <type>Mission</type>
            <Internal_Reference>
                <lid_reference>urn:nasa:pds:context:investigation:mission.test</lid_reference>
                <reference_type>data_to_investigation</reference_type>
            </Internal_Reference>
        </Investigation_Area>
        <Observing_System>
            <Observing_System_Component>
                <name>Test Instrument</name>
                <type>Instrument</type>
                <Internal_Reference>
                    <lid_reference>urn:nasa:pds:context:instrument:test.instrument</lid_reference>
                    <reference_type>is_instrument</reference_type>
                </Internal_Reference>
            </Observing_System_Component>
        </Observing_System>
        <Target_Identification>
            <name>Test Target</name>
            <type>Planet</type>
            <Internal_Reference>
                <lid_reference>urn:nasa:pds:context:target:planet.test</lid_reference>
                <reference_type>data_to_target</reference_type>
            </Internal_Reference>
        </Target_Identification>
        <Discipline_Area>
            <!-- Simulates a discipline LDD (e.g., SB, SP) element that contains
                 an Internal_Reference to a raw or related product. Before the fix for
                 issue 1481, this reference would NOT be checked for referential integrity. -->
            <testldd:Calibration_Information>
                <testldd:Raw_Data_Product>
                    <Internal_Reference>
                        <!-- product_b intentionally does not exist in the bundle;
                             this reference should generate a reference_not_found warning -->
                        <lid_reference>urn:nasa:pds:test1481:data:product_b</lid_reference>
                        <reference_type>data_to_raw_source_product</reference_type>
                    </Internal_Reference>
                </testldd:Raw_Data_Product>
            </testldd:Calibration_Information>
        </Discipline_Area>
    </Observation_Area>
</Product_Observational>
