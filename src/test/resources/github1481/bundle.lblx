<?xml version="1.0" encoding="UTF-8"?>
<?xml-model href="https://pds.nasa.gov/pds4/pds/v1/PDS4_PDS_1J00.sch" schematypens="http://purl.oclc.org/dsdl/schematron"?>

<Product_Bundle xmlns="http://pds.nasa.gov/pds4/pds/v1" 
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
    xsi:schemaLocation="http://pds.nasa.gov/pds4/pds/v1 https://pds.nasa.gov/pds4/pds/v1/PDS4_PDS_1J00.xsd">

    <Identification_Area>
        <logical_identifier>urn:nasa:pds:nh_leisa</logical_identifier>
        <version_id>2.0</version_id>
        <title>New Horizons Linear Etalon Imaging Spectral Array Instrument Archive Bundle</title>
        <information_model_version>1.19.0.0</information_model_version>
        <product_class>Product_Bundle</product_class>
        
        <Citation_Information>
            <publication_year>2025</publication_year>
            <description>This bundle contains collections of raw and calibrated
                data from the Linear Etalon Imaging Spectral Array (LEISA) instrument onboard the New Horizons
                spacecraft, as well as a calibration collection of ancillary
                files used to calibrate the data from raw to calibrated.
            </description>
        </Citation_Information>
        
        <Modification_History>
            <Modification_Detail>
                <modification_date>2025-05-01</modification_date>
                <version_id>2.0</version_id>
                <description>(SBN:T. Barnes) Adding Pluto Encounter Raw/Calibrated collections from PDS4 migration by PDS-SBN.  Updated the readme.txt file to be more generic.</description>
            </Modification_Detail>
            <Modification_Detail>
                <modification_date>2024-08-06</modification_date>
                <version_id>1.0</version_id>
                <description>Created during PDS4 migration by PDS-SBN (B. Sharkey).</description>
            </Modification_Detail>
        </Modification_History>
    </Identification_Area>

    <Context_Area>
        <Investigation_Area>
            <name>New Horizons</name>
            <type>Mission</type>
            <Internal_Reference>
                <lid_reference>urn:nasa:pds:context:investigation:mission.new_horizons</lid_reference>
                <reference_type>bundle_to_investigation</reference_type>
            </Internal_Reference>
        </Investigation_Area>
		
        <Investigation_Area>
            <name>New Horizons Kuiper Belt Extended Mission 1</name>
            <type>Mission</type>
            <Internal_Reference>
                <lid_reference>urn:nasa:pds:context:investigation:mission.new_horizons_kem1</lid_reference>
                <reference_type>bundle_to_investigation</reference_type>
            </Internal_Reference>
        </Investigation_Area>

        <Observing_System>
            <Observing_System_Component>
                <name>New Horizons</name>
                <type>Host</type>
                <Internal_Reference>
                    <lid_reference>urn:nasa:pds:context:instrument_host:spacecraft.nh</lid_reference>
                    <reference_type>is_instrument_host</reference_type>
                </Internal_Reference>
            </Observing_System_Component>

            <Observing_System_Component>
                <name>Linear Etalon Imaging Spectral Array</name>
                <type>Instrument</type>
                <description>LEISA is a wedged etalon infrared spectral imager that operates in a          
                    push-broom mode, covering 1250-2500 nm. LEISA is part of the RALPH instrument package.</description>
                <Internal_Reference>
                    <lid_reference>urn:nasa:pds:context:instrument:nh.leisa</lid_reference>
                    <reference_type>is_instrument</reference_type>
                </Internal_Reference>
            </Observing_System_Component>
        </Observing_System>
    </Context_Area>

    <Reference_List>
        <Internal_Reference>
            <lid_reference>urn:nasa:pds:nh_documents:mission</lid_reference>
            <reference_type>bundle_to_document</reference_type>
            <comment>Document collection for the New Horizons mission.</comment>
        </Internal_Reference>

        <Internal_Reference>
            <lid_reference>urn:nasa:pds:nh_documents:ralph</lid_reference>
            <reference_type>bundle_to_document</reference_type>
            <comment>Document collection for the Ralph instrument package, which houses both LEISA and MVIC.
            </comment>
        </Internal_Reference>
    </Reference_List>

    <Bundle>
        <bundle_type>Archive</bundle_type>
    </Bundle>

    <File_Area_Text>
        <File>
            <file_name>readme.txt</file_name>
        </File>

        <Stream_Text>
            <offset unit="byte">0</offset>
            <parsing_standard_id>UTF-8 Text</parsing_standard_id>
            <record_delimiter>Carriage-Return Line-Feed</record_delimiter>
        </Stream_Text>
    </File_Area_Text>

    <Bundle_Member_Entry>
        <lidvid_reference>urn:nasa:pds:nh_leisa:pluto_raw::1.0</lidvid_reference>
        <member_status>Primary</member_status>
        <reference_type>bundle_has_data_collection</reference_type>
    </Bundle_Member_Entry>

    <Bundle_Member_Entry>
        <lidvid_reference>urn:nasa:pds:nh_leisa:pluto_cal::1.0</lidvid_reference>
        <member_status>Primary</member_status>
        <reference_type>bundle_has_data_collection</reference_type>
    </Bundle_Member_Entry>

</Product_Bundle>
